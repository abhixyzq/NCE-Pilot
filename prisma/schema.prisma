datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  STUDENT
  TEACHER
  ADMIN
}

enum TestStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum QuestionType {
  OBJECTIVE
  MCQ_MULTIPLE
  SUBJECTIVE
  CODING
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

enum SubmissionVerdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
}

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  passwordHash String
  fullName     String
  avatarUrl    String?
  role         RoleType  @default(STUDENT)
  collegeName  String?
  xp           Int       @default(0)

  attempts     TestAttempt[]
  submissions  CodeSubmission[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Test {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  code                String     @unique
  title               String
  subject             String
  department          String?
  durationMinutes     Int        @default(60)
  totalMarks          Int        @default(0)
  passingMarks        Int        @default(40)
  status              TestStatus @default(PUBLISHED)
  instructions        String?

  enableFullscreen    Boolean    @default(true)
  enableRandomize     Boolean    @default(true)
  enableNegativeMarks Boolean    @default(false)
  negativeRatio       Float      @default(0.25)
  autoSubmit          Boolean    @default(true)

  creatorEmail        String
  questionIds         String[]
  questions           Question[]
  attempts            TestAttempt[]

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

type McqOption {
  optionText String
  isCorrect  Boolean @default(false)
}

type TestCase {
  input          String
  expectedOutput String
  isHidden       Boolean @default(false)
  weight         Int     @default(1)
}

model Question {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  testId           String?      @db.ObjectId
  test             Test?        @relation(fields: [testId], references: [id], onDelete: Cascade)
  type             QuestionType
  subject          String
  topic            String?
  difficulty       String       @default("Medium")
  prompt           String
  marks            Int          @default(10)
  explanation      String?

  // MCQ & Objective options
  mcqOptions       McqOption[]

  // Subjective fields
  subjectiveAnswer String?
  maxWordCount     Int?         @default(500)

  // Coding embedded fields & test cases
  codingTitle      String?
  statement        String?
  inputFormat      String?
  outputFormat     String?
  constraints      String?
  timeLimitMs      Int          @default(2000)
  memoryLimitMb    Int          @default(256)
  testCases        TestCase[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model TestAttempt {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  testId          String        @db.ObjectId
  test            Test          @relation(fields: [testId], references: [id])
  userId          String        @db.ObjectId
  user            User          @relation(fields: [userId], references: [id])
  status          AttemptStatus @default(NOT_STARTED)

  mcqScore        Float         @default(0)
  codingScore     Float         @default(0)
  subjectiveScore Float         @default(0)
  totalScore      Float         @default(0)
  accuracy        Float         @default(0)
  timeTakenSec    Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CodeSubmission {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  userId          String            @db.ObjectId
  user            User              @relation(fields: [userId], references: [id])
  questionId      String            @db.ObjectId
  language        String
  sourceCode      String
  verdict         SubmissionVerdict @default(PENDING)
  executionTimeMs Int?
  memoryUsedKb    Int?
  passedTestCases Int               @default(0)
  totalTestCases  Int               @default(0)
  obtainedMarks   Float             @default(0)
  aiSummary       String?

  createdAt       DateTime          @default(now())
}
